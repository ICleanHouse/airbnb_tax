DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DATABASE_URL=postgres://airbnb_cleaners:airbnb_cleaners@db:5432/airbnb_cleaners
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
DEFAULT_FROM_EMAIL=noreply@example.local
NEXT_PUBLIC_API_URL=http://localhost:8000/api
FRONTEND_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email — console backend prints to stdout in local dev (no SMTP needed).
# Switch to smtp backend and fill the SMTP vars for staging/production.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
