DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
APP_ENV=local
LOG_LEVEL=INFO
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
POSTGRES_DB=airbnb_cleaners
POSTGRES_USER=airbnb_cleaners
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://airbnb_cleaners:airbnb_cleaners@db:5432/airbnb_cleaners
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_URL=redis://redis:6379/2
# Server-only Geoapify credential for the approved-host geocoding proxy. Never
# expose this value as a NEXT_PUBLIC_* variable or send it to the browser.
GEOAPIFY_API_KEY=
# Keep under the Geoapify plan cap; the backend also applies its own user limit.
GEOAPIFY_PROVIDER_REQUESTS_PER_SECOND=4
NEXT_PUBLIC_API_URL=http://localhost:8000/api
FRONTEND_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
MARKETPLACE_SUPPORT_CHANNEL=support
BACKEND_URL=http://localhost:8000

# Email confirmation - Resend only. EMAIL_RESEND_FROM_EMAIL must be a verified Resend sender.
EMAIL_RESEND_APIKEY=
EMAIL_RESEND_FROM_EMAIL=
DEFAULT_FROM_EMAIL=noreply@example.local
EMAIL_VER_USER_SIGNUP=True
EMAIL_VER_USER_CONFIRMATION=True
EMAIL_NOTIF_ADMIN_NEW_ACCOUNT=True
EMAIL_NOTIF_HOST_APPLICATION_SUBMITTED=True
EMAIL_NOTIF_HOST_JOB_COMPLETED=True

# Contact-based account and cleaner eligibility. Keep these safe defaults for
# normal local, staging, pilot, and production operation.
ACCOUNT_APPROVAL_REQUIRED=True
CLEANER_VERIFICATION_REQUIRED=True
ALLOW_PILOT_VERIFICATION_BYPASS=False
PHONE_VERIFICATION_REQUIRED=False

# Required only for an explicit time-bounded staging/pilot/production bypass.
# Genuine job intake must be paused for the entire active window.
PILOT_VERIFICATION_BYPASS_OWNER=
PILOT_VERIFICATION_BYPASS_REASON=
PILOT_VERIFICATION_BYPASS_START_AT=
PILOT_VERIFICATION_BYPASS_END_AT=
PILOT_GENUINE_JOB_INTAKE_PAUSED=False

